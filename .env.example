# ──────────────────────────────────────
# DATABASE
# ──────────────────────────────────────
DATABASE_URL="postgresql://propadmin:propadmin123@localhost:5432/propadmin_db"
DB_USER=propadmin
DB_PASSWORD=propadmin123
DB_NAME=propadmin_db

# ──────────────────────────────────────
# JWT AUTH
# ──────────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_key_32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────
# SERVER
# ──────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ──────────────────────────────────────
# EMAIL (nodemailer)
# ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="PropAdmin <noreply@propadmin.com>"

# ──────────────────────────────────────
# UPLOADS
# ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ──────────────────────────────────────
# FINANCIERO
# ──────────────────────────────────────
DEFAULT_INTEREST_RATE=0.03
