generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// MULTI-TENANT: Companies (administradoras)
// ─────────────────────────────────────────────────────────────

model Company {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  phone       String?
  address     String?
  city        String?
  country     String    @default("UY")
  logo        String?
  plan        Plan      @default(STARTER)
  isActive    Boolean   @default(true)
  settings    Json?     // { interestRate, currency, timezone, ... }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users       User[]
  buildings   Building[]
  documents   Document[]

  @@index([email])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  companyId       String
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  phone           String?
  avatar          String?
  role            Role      @default(EMPLOYEE)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company         Company   @relation(fields: [companyId], references: [id])
  resident        Resident?
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// BUILDINGS
// ─────────────────────────────────────────────────────────────

model Building {
  id              String    @id @default(cuid())
  companyId       String
  name            String
  address         String
  city            String
  department      String?
  zipCode         String?
  totalUnits      Int
  reserveFund     Decimal   @default(0) @db.Decimal(12, 2)
  adminFee        Decimal   @default(0) @db.Decimal(12, 2)
  interestRate    Decimal   @default(0.03) @db.Decimal(5, 4)
  currency        String    @default("UYU")
  isActive        Boolean   @default(true)
  imageUrl        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company         Company   @relation(fields: [companyId], references: [id])
  apartments      Apartment[]
  expenses        Expense[]
  reservations    Reservation[]
  announcements   Announcement[]
  maintenanceTasks MaintenanceTask[]
  commonAreas     CommonArea[]

  @@index([companyId])
  @@map("buildings")
}

// ─────────────────────────────────────────────────────────────
// APARTMENTS / UNITS
// ─────────────────────────────────────────────────────────────

model Apartment {
  id              String          @id @default(cuid())
  buildingId      String
  number          String
  floor           String?
  coefficient     Decimal         @db.Decimal(10, 6)
  area            Decimal?        @db.Decimal(8, 2)
  bedrooms        Int?
  bathrooms       Int?
  hasParking      Boolean         @default(false)
  hasStorage      Boolean         @default(false)
  status          ApartmentStatus @default(OCCUPIED)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  building        Building        @relation(fields: [buildingId], references: [id])
  residents       Resident[]
  charges         Charge[]

  @@unique([buildingId, number])
  @@index([buildingId])
  @@map("apartments")
}

// ─────────────────────────────────────────────────────────────
// RESIDENTS (propietarios / inquilinos)
// ─────────────────────────────────────────────────────────────

model Resident {
  id              String       @id @default(cuid())
  apartmentId     String
  userId          String?      @unique
  firstName       String
  lastName        String
  email           String?
  phone           String?
  documentId      String?
  type            ResidentType
  isActive        Boolean      @default(true)
  startDate       DateTime
  endDate         DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  apartment       Apartment    @relation(fields: [apartmentId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  payments        Payment[]
  reservations    Reservation[]

  @@index([apartmentId])
  @@map("residents")
}

// ─────────────────────────────────────────────────────────────
// EXPENSES (gastos del edificio)
// ─────────────────────────────────────────────────────────────

model Expense {
  id              String          @id @default(cuid())
  buildingId      String
  category        ExpenseCategory
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  period          String          // "2024-01"
  invoiceNumber   String?
  invoiceUrl      String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  building        Building        @relation(fields: [buildingId], references: [id])
  charges         Charge[]

  @@index([buildingId, period])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// CHARGES (deudas por apartamento)
// ─────────────────────────────────────────────────────────────

model Charge {
  id              String       @id @default(cuid())
  apartmentId     String
  expenseId       String?
  description     String
  amount          Decimal      @db.Decimal(12, 2)
  dueDate         DateTime
  period          String       // "2024-01"
  status          ChargeStatus @default(PENDING)
  interestAmount  Decimal      @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal      @default(0) @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  apartment       Apartment    @relation(fields: [apartmentId], references: [id])
  expense         Expense?     @relation(fields: [expenseId], references: [id])
  paymentCharges  PaymentCharge[]

  @@index([apartmentId, status])
  @@index([apartmentId, period])
  @@map("charges")
}

// ─────────────────────────────────────────────────────────────
// PAYMENTS (pagos registrados)
// ─────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  residentId      String
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  reference       String?
  receiptUrl      String?
  date            DateTime
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  resident        Resident      @relation(fields: [residentId], references: [id])
  paymentCharges  PaymentCharge[]

  @@index([residentId])
  @@map("payments")
}

model PaymentCharge {
  paymentId       String
  chargeId        String
  amount          Decimal  @db.Decimal(12, 2)

  payment         Payment  @relation(fields: [paymentId], references: [id])
  charge          Charge   @relation(fields: [chargeId], references: [id])

  @@id([paymentId, chargeId])
  @@map("payment_charges")
}

// ─────────────────────────────────────────────────────────────
// COMMON AREAS + RESERVATIONS
// ─────────────────────────────────────────────────────────────

model CommonArea {
  id              String    @id @default(cuid())
  buildingId      String
  name            String
  description     String?
  capacity        Int?
  pricePerUse     Decimal   @default(0) @db.Decimal(10, 2)
  openTime        String?   // "08:00"
  closeTime       String?   // "22:00"
  rules           String?
  isActive        Boolean   @default(true)
  imageUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  building        Building  @relation(fields: [buildingId], references: [id])
  reservations    Reservation[]

  @@index([buildingId])
  @@map("common_areas")
}

model Reservation {
  id              String            @id @default(cuid())
  buildingId      String
  commonAreaId    String
  residentId      String
  startDateTime   DateTime
  endDateTime     DateTime
  status          ReservationStatus @default(PENDING)
  totalCost       Decimal           @default(0) @db.Decimal(10, 2)
  notes           String?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  building        Building    @relation(fields: [buildingId], references: [id])
  commonArea      CommonArea  @relation(fields: [commonAreaId], references: [id])
  resident        Resident    @relation(fields: [residentId], references: [id])

  @@index([buildingId, startDateTime])
  @@index([commonAreaId, startDateTime])
  @@map("reservations")
}

// ─────────────────────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────────────────────

model Announcement {
  id              String    @id @default(cuid())
  buildingId      String
  title           String
  content         String
  isImportant     Boolean   @default(false)
  publishedAt     DateTime  @default(now())
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  building        Building  @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────
// MAINTENANCE TASKS
// ─────────────────────────────────────────────────────────────

model MaintenanceTask {
  id              String              @id @default(cuid())
  buildingId      String
  title           String
  description     String?
  category        MaintenanceCategory
  priority        Priority            @default(MEDIUM)
  status          TaskStatus          @default(PENDING)
  assignedTo      String?
  scheduledDate   DateTime?
  completedDate   DateTime?
  cost            Decimal?            @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  building        Building            @relation(fields: [buildingId], references: [id])

  @@index([buildingId, status])
  @@map("maintenance_tasks")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────────────────────

model Document {
  id              String           @id @default(cuid())
  companyId       String
  buildingId      String?
  name            String
  description     String?
  category        DocumentCategory
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  uploadedById    String
  isPublic        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  company         Company          @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([buildingId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  action      String   // "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity      String   // "Payment", "Expense", etc.
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  EMPLOYEE
  RESIDENT
}

enum ApartmentStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum ResidentType {
  OWNER
  TENANT
}

enum ExpenseCategory {
  ELECTRICITY
  WATER
  CLEANING
  ELEVATOR
  MAINTENANCE
  CONCIERGE
  INSURANCE
  ADMINISTRATION
  RESERVE_FUND
  OTHER
}

enum ChargeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  ONLINE
  OTHER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  CLEANING
  ELEVATOR
  SECURITY
  GARDEN
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentCategory {
  REGULATION
  MEETING_MINUTES
  CONTRACT
  INVOICE
  CERTIFICATE
  OTHER
}
